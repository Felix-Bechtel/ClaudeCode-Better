#!/bin/bash
# Auto-update ClaudeCode-Better settings pack from GitHub
# Default behavior: check only + mark a "pending update" flag, so Claude can
# prompt the user at session start before installing.
#
# Flags:
#   (no flag)  — check only, print status, write pending marker if newer
#   --yes      — user said yes: install now
#   --auto     — install without any gating (legacy behavior)
#   --check    — alias for no-flag

REPO="Felix-Bechtel/ClaudeCode-Better"
LOCAL_DIR="$HOME/Claude/Claude Code Settings/Claude Code Zips"
CACHE_FILE="${TMPDIR:-/tmp}/claudecode-update-last"
PENDING_FILE="${TMPDIR:-/tmp}/claudecode-update-pending"
GREEN='\033[32m'
YEL='\033[33m'
DIM='\033[2m'
BOLD='\033[1m'
R='\033[0m'

MODE="prompt"
case "$1" in
  --auto)  MODE="auto" ;;
  --yes)   MODE="yes" ;;
  --check) MODE="prompt" ;;
esac

# Get latest commit SHA from GitHub (with timeout — never hang the session)
REMOTE_SHA=$(GH_PROMPT_DISABLED=1 perl -e 'alarm 15; exec @ARGV' gh api "repos/$REPO/commits/main" --jq '.sha' 2>/dev/null | head -c 7)
if [ -z "$REMOTE_SHA" ]; then
  printf "  ${DIM}Update check: couldn't reach GitHub${R}\n"
  exit 0
fi

LOCAL_SHA=""
[ -f "$CACHE_FILE" ] && LOCAL_SHA=$(cat "$CACHE_FILE")

if [ "$REMOTE_SHA" = "$LOCAL_SHA" ]; then
  printf "  ${GREEN}✓${R} ClaudeCode-Better is up to date ${DIM}($REMOTE_SHA)${R}\n"
  rm -f "$PENDING_FILE"
  exit 0
fi

printf "  ${YEL}⟳${R} ${BOLD}ClaudeCode-Better update available${R} ${DIM}${LOCAL_SHA:-none} → $REMOTE_SHA${R}\n"
echo "$REMOTE_SHA" > "$PENDING_FILE"

if [ "$MODE" = "prompt" ]; then
  printf "  ${DIM}Claude will ask if you want to install. Or run: claudecode-update --yes${R}\n"
  exit 0
fi

# MODE is "auto" or "yes" — proceed with install.
printf "  ${DIM}Downloading latest zips...${R}\n"
mkdir -p "$LOCAL_DIR"

# Hard timeout helper — macOS lacks `timeout`, so use perl's alarm.
run_with_timeout() {
  local secs="$1"; shift
  perl -e 'alarm shift; exec @ARGV' "$secs" "$@"
}

CC_URL=$(run_with_timeout 15 gh api "repos/$REPO/contents/Claude Code Zips/ClaudeCode.zip" --jq '.download_url' 2>/dev/null)
BS_URL=$(run_with_timeout 15 gh api "repos/$REPO/contents/Claude Code Zips/buddy-system.zip" --jq '.download_url' 2>/dev/null)
[ -n "$CC_URL" ] && curl -sL --connect-timeout 10 --max-time 90 "$CC_URL" -o "$LOCAL_DIR/ClaudeCode.zip.tmp"
[ -n "$BS_URL" ] && curl -sL --connect-timeout 10 --max-time 90 "$BS_URL" -o "$LOCAL_DIR/buddy-system.zip.tmp"

if [ -s "$LOCAL_DIR/ClaudeCode.zip.tmp" ] && [ -s "$LOCAL_DIR/buddy-system.zip.tmp" ]; then
  mv "$LOCAL_DIR/ClaudeCode.zip.tmp" "$LOCAL_DIR/ClaudeCode.zip"
  mv "$LOCAL_DIR/buddy-system.zip.tmp" "$LOCAL_DIR/buddy-system.zip"

  # --- STEP 1: install buddy-system FIRST (the real buddy Claude built) ---
  BTMP=$(mktemp -d)
  unzip -qo "$LOCAL_DIR/buddy-system.zip" -d "$BTMP" 2>/dev/null
  if [ -f "$BTMP/buddy.js" ]; then
    BUDDY_DEST="$HOME/Claude/buddy-system"
    mkdir -p "$BUDDY_DEST"
    cp "$BTMP/buddy.js" "$BUDDY_DEST/buddy.js"
    [ -f "$BTMP/buddy-collection-default.json" ] && cp "$BTMP/buddy-collection-default.json" "$BUDDY_DEST/buddy-collection-default.json"
    [ -f "$BTMP/README.md" ] && cp "$BTMP/README.md" "$BUDDY_DEST/README.md"
    [ -f "$BTMP/Info.md" ] && cp "$BTMP/Info.md" "$BUDDY_DEST/Info.md"
    [ -f "$BTMP/INSTALL-FOR-CLAUDE.md" ] && cp "$BTMP/INSTALL-FOR-CLAUDE.md" "$BUDDY_DEST/INSTALL-FOR-CLAUDE.md"
    if [ ! -f "$HOME/.claude/buddy-collection.json" ] && [ -f "$BTMP/buddy-collection-default.json" ]; then
      cp "$BTMP/buddy-collection-default.json" "$HOME/.claude/buddy-collection.json"
    fi
    printf "  ${GREEN}✓${R} buddy-system installed\n"
  fi
  rm -rf "$BTMP"

  # --- STEP 2: install ClaudeCode overlays (DLC layered over buddy) ---
  TMPEXT=$(mktemp -d)
  unzip -qo "$LOCAL_DIR/ClaudeCode.zip" -d "$TMPEXT"
  if [ -d "$TMPEXT/commands" ]; then
    mkdir -p "$HOME/.claude/commands"
    cp "$TMPEXT/commands/"*.md "$HOME/.claude/commands/" 2>/dev/null
  fi
  if [ -d "$TMPEXT/bin" ]; then
    mkdir -p "$HOME/.claude/bin"
    cp "$TMPEXT/bin/"* "$HOME/.claude/bin/" 2>/dev/null
    chmod +x "$HOME/.claude/bin/"* 2>/dev/null
  fi

  # statusline.py + CLAUDE.md are not user-customized — refresh them so bug
  # fixes (e.g. flicker, hook JSON shape) propagate to existing installs
  # without forcing the user to re-run install.sh. settings.json is left
  # alone because users edit it (env vars, plugins, statusline overrides).
  SETTINGS_DEST="$HOME/Claude/Claude Code Settings"
  mkdir -p "$SETTINGS_DEST"
  for f in statusline.py statusline.js CLAUDE.md; do
    if [ -f "$TMPEXT/$f" ]; then
      cp "$TMPEXT/$f" "$SETTINGS_DEST/$f"
      # Mirror to ~/.claude/$f if it isn't already a symlink to SETTINGS_DEST.
      if [ ! -L "$HOME/.claude/$f" ] && [ -e "$HOME/.claude/$f" ]; then
        cp "$TMPEXT/$f" "$HOME/.claude/$f"
      elif [ ! -e "$HOME/.claude/$f" ]; then
        ln -sfn "$SETTINGS_DEST/$f" "$HOME/.claude/$f"
      fi
    fi
  done

  rm -rf "$TMPEXT"
  printf "  ${GREEN}✓${R} ClaudeCode overlays installed\n"

  echo "$REMOTE_SHA" > "$CACHE_FILE"
  rm -f "$PENDING_FILE"
  printf "  ${GREEN}✓${R} ${BOLD}Updated!${R} ClaudeCode-Better synced to $REMOTE_SHA\n"

  if command -v buddy &>/dev/null; then
    printf "  ${DIM}Buddy collection:${R}\n"
    buddy stats 2>/dev/null
  fi
else
  rm -f "$LOCAL_DIR/ClaudeCode.zip.tmp" "$LOCAL_DIR/buddy-system.zip.tmp"
  printf "  ${YEL}⚠${R} Download failed, keeping current version\n"
fi
