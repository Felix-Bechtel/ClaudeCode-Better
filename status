#!/bin/bash
# Claude Code Status — quick setup overview

printf "\033[1m=== Claude Code Status ===\033[0m\n\n"

# Model & permissions
if [ -f ~/.claude/settings.json ]; then
  model=$(python3 -c "import json; d=json.load(open('$HOME/.claude/settings.json')); print(d.get('model','unknown'))" 2>/dev/null)
  mode=$(python3 -c "import json; d=json.load(open('$HOME/.claude/settings.json')); print(d.get('permissions',{}).get('defaultMode','unknown'))" 2>/dev/null)
  printf "  \033[32m✓\033[0m Model: %s\n" "$model"
  printf "  \033[32m✓\033[0m Permissions: %s\n" "$mode"
else
  printf "  \033[31m✗\033[0m settings.json not found\n"
fi

# Plugins
printf "\n\033[1mPlugins:\033[0m\n"
if command -v claude &>/dev/null; then
  claude plugins list 2>/dev/null | while read -r line; do
    printf "  \033[32m✓\033[0m %s\n" "$line"
  done
else
  printf "  \033[33m?\033[0m claude CLI not in PATH\n"
fi

# Commands
printf "\n\033[1mCommands:\033[0m\n"
if [ -d ~/.claude/commands ]; then
  for f in ~/.claude/commands/*.md; do
    [ -f "$f" ] && printf "  \033[32m✓\033[0m /%s\n" "$(basename "$f" .md)"
  done
else
  printf "  \033[31m✗\033[0m commands dir not found\n"
fi

# Keep-awake
printf "\n\033[1mKeep-Awake:\033[0m\n"
if pgrep -f caffeinate >/dev/null 2>&1; then
  printf "  \033[32m✓\033[0m Active\n"
else
  printf "  \033[90m-\033[0m Inactive\n"
fi

# Statusline
printf "\n\033[1mStatusline:\033[0m\n"
if [ -f ~/.claude/statusline.py ]; then
  printf "  \033[32m✓\033[0m statusline.py present\n"
else
  printf "  \033[31m✗\033[0m statusline.py missing\n"
fi

printf "\n"
